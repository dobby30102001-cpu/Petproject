# Copy this file to `.env` in the same directory and fill in real values.
# The .env file is loaded automatically by docker compose and is git-ignored.

# Gmail SMTP account used by the backend to send OTP / notification mail.
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-app-password

# HS256 signing key for JWT. Must be at least 32 characters.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
